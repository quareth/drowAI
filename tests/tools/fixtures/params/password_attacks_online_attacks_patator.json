{
  "tool_id": "password_attacks.online_attacks.patator",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "http://example.com",
        "module": "ftp_login",
        "host": "192.168.1.1"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "http://example.com",
        "module": "ftp_login",
        "host": "192.168.1.1",
        "timeout": 100,
        "port": 100,
        "user_file": "full_user_file",
        "password_file": "full_password_file",
        "user": "full_user",
        "password": "full_password",
        "output_format": "json",
        "verbose": true,
        "output_file": "full_output_file",
        "max_attempts": 100,
        "extra_args": [
          "option1",
          "option2"
        ]
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "timeout_min",
        "params": {
          "target": "http://example.com",
          "module": "ftp_login",
          "host": "192.168.1.1",
          "timeout": 60
        },
        "expected_valid": true
      },
      {
        "name": "timeout_max",
        "params": {
          "target": "http://example.com",
          "module": "ftp_login",
          "host": "192.168.1.1",
          "timeout": 3600
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_required",
        "params": {},
        "expected_error": "required"
      },
      {
        "name": "timeout_below_min",
        "params": {
          "target": "http://example.com",
          "module": "ftp_login",
          "host": "192.168.1.1",
          "timeout": 59
        },
        "expected_error": "timeout"
      },
      {
        "name": "timeout_above_max",
        "params": {
          "target": "http://example.com",
          "module": "ftp_login",
          "host": "192.168.1.1",
          "timeout": 3601
        },
        "expected_error": "timeout"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [
      "^patator"
    ],
    "full": [
      "^patator"
    ]
  }
}