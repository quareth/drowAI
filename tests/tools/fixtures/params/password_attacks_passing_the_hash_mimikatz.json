{
  "tool_id": "password_attacks.passing_the_hash.mimikatz",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "http://example.com"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "http://example.com",
        "timeout": 100,
        "command": "sekurlsa::pth",
        "username": "full_username",
        "domain": "full_domain",
        "ntlm_hash": "full_ntlm_hash",
        "aes256_hash": "full_aes256_hash",
        "output_format": "json",
        "output_file": "full_output_file",
        "elevated": true,
        "debug": true,
        "verbose": true,
        "target_host": "full_target_host",
        "target_user": "full_target_user",
        "kerberos_ticket": "full_kerberos_ticket",
        "masterkey_file": "full_masterkey_file",
        "vault_guid": "full_vault_guid"
      },
      "expected_valid": true
    },
    "edge_cases": [],
    "invalid": [
      {
        "name": "missing_required",
        "params": {},
        "expected_error": "required"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [
      "^mimikatz"
    ],
    "full": [
      "^mimikatz"
    ]
  }
}