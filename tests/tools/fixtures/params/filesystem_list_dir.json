{
  "tool_id": "filesystem.list_dir",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "path": "artifacts"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "path": "artifacts",
        "recursive": true,
        "include_hidden": true,
        "include_globs": [
          "*.txt"
        ],
        "exclude_globs": [
          "*.bak"
        ],
        "max_results": 500
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "description": "Non-recursive hidden inclusion",
        "params": {
          "path": ".",
          "include_hidden": true
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "description": "Absolute path rejected",
        "params": {
          "path": "/var/log"
        },
        "expected_valid": false,
        "expected_error": "Absolute paths"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [],
    "full": []
  }
}