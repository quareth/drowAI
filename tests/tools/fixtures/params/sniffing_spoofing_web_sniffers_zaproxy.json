{
  "tool_id": "sniffing_spoofing.web_sniffers.zaproxy",
  "test_cases": {
    "minimal": {
      "description": "Basic ZAP baseline scan",
      "params": {
        "target": "unused",
        "target_url": "http://example.com",
        "report_format": "html"
      },
      "expected_valid": true
    },
    "full": {
      "description": "Full ZAP baseline options",
      "params": {
        "target": "unused",
        "target_url": "http://example.com",
        "report_format": "json",
        "report_file": "report.json",
        "config_file": "zap.conf",
        "rules_file": "rules.conf",
        "ajax_spider": true,
        "verbose": true,
        "extra_args": [
          "-d"
        ]
      },
      "expected_valid": true
    },
    "edge_cases": [],
    "invalid": [
      {
        "name": "missing_target_url",
        "params": {
          "target": "unused"
        },
        "expected_error": "required"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [
      "^zap-baseline"
    ],
    "full": [
      "^zap-baseline",
      "-t"
    ]
  }
}