{
  "tool_id": "filesystem.find_paths",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "path": "."
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "path": "reports",
        "filename_glob": "*.txt",
        "include_globs": [
          "*.txt"
        ],
        "exclude_globs": [
          "*.bak"
        ],
        "max_depth": 3,
        "min_depth": 1,
        "file_types": [
          "file"
        ],
        "follow_symlinks": false,
        "max_results": 100
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "description": "Directory-only results",
        "params": {
          "path": "reports",
          "file_types": [
            "directory"
          ]
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "description": "Path traversal attempt",
        "params": {
          "path": "../outside"
        },
        "expected_valid": false,
        "expected_error": "escapes the workspace"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [],
    "full": []
  }
}