        "verbose": true
      },
      "expected_valid": true
    },
    "edge_cases": [],
    "invalid": []
  },
  "expected_command_patterns": {
    "minimal": [
      "^showmount",
      "-e"
    ],
    "full": [
      "^showmount",
      "-a"
    ]
  }
}
