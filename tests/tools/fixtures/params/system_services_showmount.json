{
  "tool_id": "system_services.showmount",
  "test_cases": {
    "minimal": {
      "description": "List exports with default options",
      "params": {
        "target": "192.168.1.1"
      },
      "expected_valid": true
    },
    "full": {
      "description": "List all mounts with verbose output",
      "params": {
        "target": "192.168.1.1",
