{
  "tool_id": "password_attacks.offline_attacks.crunch",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "http://example.com",
        "min_length": 4,
        "max_length": 8
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "http://example.com",
        "min_length": 4,
        "max_length": 8,
        "timeout": 100,
        "charset": "abc123",
        "pattern": "@@@@",
        "start": "aaaa",
        "end": "zzzz",
        "lines_per_file": 100,
        "output_file": "wordlist.txt"
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "min_length_min",
        "params": {
          "target": "http://example.com",
          "min_length": 1,
          "max_length": 1
        },
        "expected_valid": true
      },
      {
        "name": "min_length_max",
        "params": {
          "target": "http://example.com",
          "min_length": 50,
          "max_length": 50
        },
        "expected_valid": true
      },
      {
        "name": "max_length_min",
        "params": {
          "target": "http://example.com",
          "min_length": 1,
          "max_length": 1
        },
        "expected_valid": true
      },
      {
        "name": "max_length_max",
        "params": {
          "target": "http://example.com",
          "min_length": 1,
          "max_length": 50
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_required",
        "params": {},
        "expected_error": "required"
      },
      {
        "name": "min_length_below_min",
        "params": {
          "target": "http://example.com",
          "min_length": 0,
          "max_length": 8
        },
        "expected_error": "min_length"
      },
      {
        "name": "min_length_above_max",
        "params": {
          "target": "http://example.com",
          "min_length": 51,
          "max_length": 51
        },
        "expected_error": "min_length"
      },
      {
        "name": "max_length_below_min",
        "params": {
          "target": "http://example.com",
          "min_length": 1,
          "max_length": 0
        },
        "expected_error": "max_length"
      },
      {
        "name": "max_length_above_max",
        "params": {
          "target": "http://example.com",
          "min_length": 1,
          "max_length": 51
        },
        "expected_error": "max_length"
      },
      {
        "name": "max_less_than_min",
        "params": {
          "target": "http://example.com",
          "min_length": 10,
          "max_length": 5
        },
        "expected_error": "max_length"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [
      "^crunch"
    ],
    "full": [
      "^crunch"
    ]
  }
}