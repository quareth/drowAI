{
  "tool_id": "password_attacks.passing_the_hash.passing_the_hash_toolkit",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "192.168.1.100",
        "username": "administrator",
        "hash_value": "aad3b435b51404eeaad3b435b51404ee:8846f7eaee8fb117"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "192.168.1.100",
        "username": "administrator",
        "hash_value": "aad3b435b51404eeaad3b435b51404ee:8846f7eaee8fb117",
        "attack_mode": "smb",
        "hash_type": "ntlm",
        "protocol": "smb",
        "output_format": "json",
        "output_file": "/tmp/pth_output.json",
        "port": 445,
        "timeout": 60,
        "verbose": true,
        "quiet": false,
        "include_metadata": true,
        "domain": "WORKGROUP",
        "service": "admin$",
        "command": "whoami",
        "session_name": "pth_session_1",
        "brute_force": false,
        "wordlist": "/usr/share/wordlists/rockyou.txt",
        "threads": 10,
        "common_timeout": 600
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "min_threads",
        "params": {
          "target": "192.168.1.100",
          "username": "administrator",
          "hash_value": "aad3b435b51404eeaad3b435b51404ee:8846f7eaee8fb117",
          "threads": 1
        },
        "expected_valid": true
      },
      {
        "name": "max_threads",
        "params": {
          "target": "192.168.1.100",
          "username": "administrator",
          "hash_value": "aad3b435b51404eeaad3b435b51404ee:8846f7eaee8fb117",
          "threads": 50
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_required",
        "params": {},
        "expected_error": "required"
      },
      {
        "name": "threads_above_max",
        "params": {
          "target": "192.168.1.100",
          "username": "administrator",
          "hash_value": "aad3b435b51404eeaad3b435b51404ee:8846f7eaee8fb117",
          "threads": 51
        },
        "expected_error": "threads"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": ["pth-toolkit"],
    "full": ["pth-toolkit"]
  }
}
