{
  "tool_id": "information_gathering.dns.dnsmap",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "example.com",
        "target_domain": "example.com"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "example.com",
        "target_domain": "example.com",
        "scan_mode": "brute_force",
        "wordlist_file": "/usr/share/wordlists/dnsmap.txt",
        "dns_server": "8.8.8.8",
        "timeout": 60,
        "output_format": "json"
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "minimal_timeout",
        "params": {
          "target": "example.com",
          "target_domain": "example.com",
          "timeout": 1
        },
        "expected_valid": true
      },
      {
        "name": "max_timeout",
        "params": {
          "target": "example.com",
          "target_domain": "example.com",
          "timeout": 300
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_target_domain",
        "params": {"target": "example.com"},
        "expected_error": "required"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": ["^dnsmap", "example.com"],
    "full": ["^dnsmap", "example.com"]
  }
}
