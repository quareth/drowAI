{
  "tool_id": "password_attacks.offline_attacks.rainbowcrack",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "http://example.com"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "http://example.com",
        "timeout": 300,
        "operation": "sort_table",
        "hash_algorithm": "ntlm",
        "output_format": "json",
        "verbose": true,
        "table_path": "/usr/share/rainbowtables/nt_loweralpha-numeric_1-7.rt",
        "table_dir": "/usr/share/rainbowtables",
        "charset": "loweralpha-numeric",
        "min_length": 1,
        "max_length": 8,
        "chain_length": 10000,
        "chain_count": 50000
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "timeout_min",
        "params": {
          "target": "http://example.com",
          "timeout": 60
        },
        "expected_valid": true
      },
      {
        "name": "timeout_max",
        "params": {
          "target": "http://example.com",
          "timeout": 7200
        },
        "expected_valid": true
      },
      {
        "name": "min_length_min",
        "params": {
          "target": "http://example.com",
          "min_length": 1
        },
        "expected_valid": true
      },
      {
        "name": "min_length_max",
        "params": {
          "target": "http://example.com",
          "min_length": 20
        },
        "expected_valid": true
      },
      {
        "name": "max_length_min",
        "params": {
          "target": "http://example.com",
          "max_length": 1
        },
        "expected_valid": true
      },
      {
        "name": "max_length_max",
        "params": {
          "target": "http://example.com",
          "max_length": 20
        },
        "expected_valid": true
      },
      {
        "name": "chain_length_min",
        "params": {
          "target": "http://example.com",
          "chain_length": 1000
        },
        "expected_valid": true
      },
      {
        "name": "chain_length_max",
        "params": {
          "target": "http://example.com",
          "chain_length": 1000000
        },
        "expected_valid": true
      },
      {
        "name": "chain_count_min",
        "params": {
          "target": "http://example.com",
          "chain_count": 1000
        },
        "expected_valid": true
      },
      {
        "name": "chain_count_max",
        "params": {
          "target": "http://example.com",
          "chain_count": 10000000
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_required",
        "params": {},
        "expected_error": "required"
      },
      {
        "name": "timeout_below_min",
        "params": {
          "target": "http://example.com",
          "timeout": 59
        },
        "expected_error": "timeout"
      },
      {
        "name": "timeout_above_max",
        "params": {
          "target": "http://example.com",
          "timeout": 7201
        },
        "expected_error": "timeout"
      },
      {
        "name": "min_length_below_min",
        "params": {
          "target": "http://example.com",
          "min_length": 0
        },
        "expected_error": "min_length"
      },
      {
        "name": "min_length_above_max",
        "params": {
          "target": "http://example.com",
          "min_length": 21
        },
        "expected_error": "min_length"
      },
      {
        "name": "max_length_below_min",
        "params": {
          "target": "http://example.com",
          "max_length": 0
        },
        "expected_error": "max_length"
      },
      {
        "name": "max_length_above_max",
        "params": {
          "target": "http://example.com",
          "max_length": 21
        },
        "expected_error": "max_length"
      },
      {
        "name": "chain_length_below_min",
        "params": {
          "target": "http://example.com",
          "chain_length": 999
        },
        "expected_error": "chain_length"
      },
      {
        "name": "chain_length_above_max",
        "params": {
          "target": "http://example.com",
          "chain_length": 1000001
        },
        "expected_error": "chain_length"
      },
      {
        "name": "chain_count_below_min",
        "params": {
          "target": "http://example.com",
          "chain_count": 999
        },
        "expected_error": "chain_count"
      },
      {
        "name": "chain_count_above_max",
        "params": {
          "target": "http://example.com",
          "chain_count": 10000001
        },
        "expected_error": "chain_count"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": ["^rainbowcrack"],
    "full": ["^rainbowcrack"]
  }
}
