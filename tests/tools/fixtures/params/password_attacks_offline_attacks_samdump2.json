{
  "tool_id": "password_attacks.offline_attacks.samdump2",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "http://example.com"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "http://example.com",
        "timeout": 100,
        "output_format": "json",
        "hash_format": "ntlm",
        "verbose": true,
        "output_file": "full_output_file",
        "system_file": "full_system_file",
        "sam_file": "full_sam_file",
        "security_file": "full_security_file",
        "bootkey": "full_bootkey",
        "local": true,
        "remote": true,
        "domain": true,
        "local_accounts": true
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "timeout_min",
        "params": {
          "target": "http://example.com",
          "timeout": 30
        },
        "expected_valid": true
      },
      {
        "name": "timeout_max",
        "params": {
          "target": "http://example.com",
          "timeout": 1800
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_required",
        "params": {},
        "expected_error": "required"
      },
      {
        "name": "timeout_below_min",
        "params": {
          "target": "http://example.com",
          "timeout": 29
        },
        "expected_error": "timeout"
      },
      {
        "name": "timeout_above_max",
        "params": {
          "target": "http://example.com",
          "timeout": 1801
        },
        "expected_error": "timeout"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [
      "^samdump2"
    ],
    "full": [
      "^samdump2"
    ]
  }
}