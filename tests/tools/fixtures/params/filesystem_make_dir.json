{
  "tool_id": "filesystem.make_dir",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "path": "artifacts/reports"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "path": "artifacts/reports",
        "parents": true,
        "exist_ok": true
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "description": "Existing directory with exist_ok",
        "params": {
          "path": "artifacts",
          "exist_ok": true
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "description": "Absolute path rejected",
        "params": {
          "path": "/etc"
        },
        "expected_valid": false,
        "expected_error": "Absolute paths"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [],
    "full": []
  }
}