{
  "tool_id": "information_gathering.dns.theharvester",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "target": "example.com",
        "target_domain": "example.com"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "target": "example.com",
        "target_domain": "example.com",
        "search_engines": ["google", "bing"],
        "output_format": "json",
        "limit": 500,
        "timeout": 300,
        "dns_server": "8.8.8.8"
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "name": "minimal_limit",
        "params": {
          "target": "example.com",
          "target_domain": "example.com",
          "limit": 1
        },
        "expected_valid": true
      },
      {
        "name": "max_limit",
        "params": {
          "target": "example.com",
          "target_domain": "example.com",
          "limit": 10000
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "name": "missing_target_domain",
        "params": {"target": "example.com"},
        "expected_error": "required"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": ["theharvester", "-d", "example.com"],
    "full": ["theharvester", "-d", "example.com"]
  }
}
