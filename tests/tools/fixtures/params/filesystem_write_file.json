{
  "tool_id": "filesystem.write_file",
  "test_cases": {
    "minimal": {
      "description": "Required fields only",
      "params": {
        "path": "reports/summary.txt",
        "content": "Scan results"
      },
      "expected_valid": true
    },
    "full": {
      "description": "All optional fields populated",
      "params": {
        "path": "reports/summary.txt",
        "content": "Updated results",
        "encoding": "utf-8",
        "create_parents": true,
        "overwrite": "overwrite"
      },
      "expected_valid": true
    },
    "edge_cases": [
      {
        "description": "Safe overwrite mode",
        "params": {
          "path": "reports/summary.txt",
          "content": "Safe update",
          "overwrite": "safe"
        },
        "expected_valid": true
      }
    ],
    "invalid": [
      {
        "description": "Absolute path rejected",
        "params": {
          "path": "/etc/passwd",
          "content": "bad"
        },
        "expected_valid": false,
        "expected_error": "Absolute paths"
      }
    ]
  },
  "expected_command_patterns": {
    "minimal": [],
    "full": []
  }
}