# Standalone — postgres, backend, frontend, runner on one Linux machine.
# Copy to repo-root `.env` only for environment-file-based bootstrap workflows.
#
# Compose-first bootstrap: set POSTGRES_PASSWORD only; the browser wizard at /setup
# completes admin account, JWT (if regenerated), runner token, and remaining settings.
#
# Host prep (Linux):
#   sudo mkdir -p /var/lib/drowai
#   sudo chown "$(id -u):$(id -g)" /var/lib/drowai

# PostgreSQL credentials (required)
POSTGRES_USER=drowai_user
POSTGRES_PASSWORD=
POSTGRES_DB=drowai

# Application secret (required for DEBUG=false compose boot; wizard writes final value)
JWT_SECRET=

# Provider credential encryption key (required; keep stable across backend rebuilds)
ENCRYPTION_KEY=

# Runner registration token (create via UI/API after first backend start)
DROWAI_RUNNER_REGISTRATION_TOKEN=
DROWAI_RUNNER_TENANT_ID=1

# Optional dev/rollback override. By default compose uses drowai/kali-pentesting:amd64-runtime.
# DROWAI_RUNTIME_IMAGE=drowai/kali-pentesting:amd64-runtime

# Optional service ports
# PostgreSQL defaults to host-local access. Set this to a specific private host
# address only when database access from a trusted management network is needed.
# POSTGRES_BIND_ADDRESS=127.0.0.1
# POSTGRES_PORT=5432
# FRONTEND_PORT=80

# Optional: override runner image tag built locally
# DROWAI_RUNNER_IMAGE=drowai/runner:local

# LLM provider API keys are configured in the setup/settings UI and stored encrypted.
