{
  "name": "drowai",
  "version": "0.1.0",
  "description": "Pre-v1 platform for task-isolated AI security workflows",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "vite build",
    "build:static": "vite build",
    "check": "tsc",
    "test:publication-safety": "python3 scripts/check_publication_safety.py",
    "test:release:quick": "python3 scripts/run_release_gate.py --tier quick",
    "test:release:main": "python3 scripts/run_release_gate.py --tier main",
    "test:release:e2e": "python3 scripts/run_release_gate.py --tier main --include-e2e",
    "test:e2e:fixture-contracts": "node --import tsx --test e2e/fixtures/*.test.ts",
    "test:e2e:fixture-contracts:quick": "node --import tsx --test e2e/fixtures/actors-domain.test.ts e2e/fixtures/artifact-policy.test.ts e2e/fixtures/runtime-local-contract.test.ts e2e/fixtures/sanitized-logs.test.ts",
    "test:e2e:pr": "cross-env DEBUG=true E2E_START_BACKEND=true E2E_DETERMINISTIC_MODE=true TASK_RUNTIME_PLACEMENT_MODE_DEFAULT=local DATABASE_URL=sqlite:///./.e2e-smoke.sqlite3 API_URL=http://127.0.0.1:18080 BASE_URL=http://127.0.0.1:15173 npx playwright test --config=e2e/playwright.config.ts --grep @pr-core --project=chromium",
    "test:e2e:journeys": "cross-env DEBUG=true E2E_START_BACKEND=true E2E_DETERMINISTIC_MODE=true TASK_RUNTIME_PLACEMENT_MODE_DEFAULT=local DATABASE_URL=sqlite:///./.e2e-journeys.sqlite3 API_URL=http://127.0.0.1:18080 BASE_URL=http://127.0.0.1:15173 npx playwright test --config=e2e/playwright.config.ts --grep @journey",
    "test:e2e:runtime:local": "cross-env DEBUG=true E2E_DETERMINISTIC_MODE=false E2E_RUNTIME_LOCAL_MODE=true TASK_RUNTIME_PLACEMENT_MODE_DEFAULT=local npx playwright test --config=e2e/playwright.config.ts --grep @runtime-local --project=chromium",
    "test:langgraph:quick": "python scripts/run_langgraph_regression_suite.py --tier quick",
    "test:langgraph:main": "python scripts/run_langgraph_regression_suite.py --tier main",
    "test:langgraph:nightly": "python scripts/run_langgraph_regression_suite.py --tier nightly",
    "test:langgraph:mock-prompts": "python scripts/run_langgraph_prompt_mock_suite.py --scenario all",
    "package:runner:check": "python3 scripts/package_runner.py --check",
    "build:runtime-image:check": "python3 scripts/build_runtime_image.py --check"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.3.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.1",
    "typescript": "5.6.3",
    "vite": "^7.3.6",
    "vitest": "^4.0.18"
  }
}
