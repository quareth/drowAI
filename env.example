# DrowAI local development environment.
# Copy to repo root: cp env.example .env

# The local parity launcher requires a separately running PostgreSQL database.
# Set DATABASE_URL before startup; SQLite is used only by tests.
# Example format:
# DATABASE_URL=postgresql://drowai_user:<POSTGRES_PASSWORD>@localhost:5432/drowai
# POSTGRES_USER=drowai_user
# POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
# POSTGRES_DB=drowai
# POSTGRES_PORT=5432

# Security overrides are optional. Leave them unset to generate stable values
# under .drowai-local/secrets. Supplied encryption keys must be valid Fernet keys.
# JWT_SECRET=
# ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1800

# Browser origins allowed to call the backend directly with credentialed requests.
# Production deployments normally use the same-origin frontend proxy.
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Optional dev/rollback override. By default the app uses drowai/kali-pentesting:<arch>-runtime.
# DROWAI_RUNTIME_IMAGE=drowai/kali-pentesting:arm64-runtime

# Logging
LOG_LEVEL=INFO
DEBUG=true

# LLM provider API keys are configured in the UI setup/settings flow and stored encrypted.

# Optional operator override for every OpenAI-compatible model route. Leave unset
# to use each route's configured provider endpoint. Public overrides require HTTPS;
# local development may use HTTP only on localhost or an explicit loopback address.
# A trailing /v1 is accepted but not required.
# DROWAI_OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:4000
